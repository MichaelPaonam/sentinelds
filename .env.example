GOOGLE_GENAI_USE_VERTEXAI="true"
GOOGLE_CLOUD_PROJECT="<your-actual-gcp-project-id>"
GOOGLE_CLOUD_LOCATION="europe-west4"

# DYNATRACE_API_URL="https://<your-dynatrace-environment-id>.live.dynatrace.com"
# DYNATRACE_API_TOKEN="<your-dynatrace-api-token>"

# Dynatrace Remote MCP Server (used by the Sentinel Agent's pre-flight gate)
# Connects to {DT_ENVIRONMENT}/platform-reserved/mcp-gateway/v0.1/servers/dynatrace-mcp/mcp
# via Streamable HTTP transport.
#
# DT_PLATFORM_TOKEN must carry these scopes:
#   - mcp-gateway:servers:invoke  (required)
#   - mcp-gateway:servers:read    (required)
#   - storage:buckets:read, storage:events:read, storage:logs:read  (for execute-dql)
# See docs/dynatrace-mcp-options.md and docs/migration_plan.md.
# DT_ENVIRONMENT="https://<your-tenant-id>.apps.dynatrace.com"
# DT_PLATFORM_TOKEN="<your-platform-token>"

# Sentinel audit sidecar (optional — leave unset for in-process gate only).
# When set, the in-process Sentinel gate fans pre-flight verdicts and
# injection-candidate events out to a separate Cloud Run service that
# re-emits them as OTel spans on the sentinelds-sentinel service entity.
# Sidecar outage cannot break the gate (errors are logged and swallowed).
# SENTINEL_AUDIT_URL="https://sentinelds-sentinel-<hash>.<region>.run.app/audit"

OTEL_SEMCONV_STABILITY_OPT_IN="gen_ai_latest_experimental"

# Agent model selection (override to switch model tier for all agents)
# DEFAULT_MODEL="gemini-2.5-flash-lite"
# THINKING_MODEL="gemini-2.5-flash"

# E2E demo defaults (override to point at your own dataset or attack server)
# E2E_DEFAULT_CSV="data/ecg_csv/ddd/01M_1.csv"
# E2E_PAPER_URL="<attack-server>/papers"
# E2E_TARGET_COL="label"
# E2E_COMBINED_CSV="data/ecg_csv/ddd/_e2e_combined.csv"

# GCS config for A2 demo artefacts (clean.csv + poisoned.csv)
# Auth via Application Default Credentials: gcloud auth application-default login
# GCS_BUCKET_NAME="<your-gcs-bucket-name>"
# A2_CLEAN_BLOB="a2/clean.csv"
# A2_POISONED_BLOB="a2/poisoned.csv"

# Attack server base URL — set to a distinct host so demo traces show an external
# attacker. Cloud Run deployment used for the live demo:
# BASE_URL=
# RESEARCH_AGENT_CARD_BASE_URL=
# FEATURE_AGENT_CARD_BASE_URL=
# MODELING_AGENT_CARD_BASE_URL=
# SENTINEL_AUDIT_URL=