GOOGLE_GENAI_USE_VERTEXAI="true"
GOOGLE_CLOUD_PROJECT="<your-actual-gcp-project-id>"
GOOGLE_CLOUD_LOCATION="europe-west4"

# GEMINI_API_KEY=

# DYNATRACE_API_URL="https://<your-dynatrace-environment-id>.live.dynatrace.com"
# DYNATRACE_API_TOKEN="<your-dynatrace-api-token>"

# Consumed by the Dynatrace MCP server subprocess that the Sentinel Agent spawns
# (see src/sentinel/dynatrace_mcp.py). Distinct from DYNATRACE_API_URL/TOKEN above
# which configure the OTLP exporter; the MCP subprocess speaks the platform API
# directly and expects its own env-var names. See docs/dynatrace-mcp-options.md.
# DT_ENVIRONMENT="https://<your-tenant-id>.apps.dynatrace.com"
# DT_PLATFORM_TOKEN="<your-platform-token>"

# 2. Dynatrace Acceptance Criteria (Metadata)
OTEL_SERVICE_NAME="<your-service-name>"
OTEL_RESOURCE_ATTRIBUTES="agent.name=<your-agent-name>"
OTEL_SEMCONV_STABILITY_OPT_IN="gen_ai_latest_experimental"
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=1
OTEL_BSP_SCHEDULE_DELAY_MILLIS=100
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT="True"

# Agent model selection (override to switch model tier for all agents)
# DEFAULT_MODEL="gemini-2.5-flash-lite"
# THINKING_MODEL="gemini-2.5-flash"

# E2E demo defaults (override to point at your own dataset or attack server)
# E2E_DEFAULT_CSV="data/ecg_csv/ddd/01M_1.csv"
# E2E_PAPER_URL="http://localhost:8001/papers"
# E2E_TARGET_COL="label"
# E2E_COMBINED_CSV="data/ecg_csv/ddd/_e2e_combined.csv"

# Attack server base URL — set to a distinct host so demo traces show an external
# attacker. Cloud Run deployment used for the live demo:
# BASE_URL="https://attack-server-443663191326.europe-west4.run.app"
# RESEARCH_AGENT_CARD_BASE_URL=
# FEATURE_AGENT_CARD_BASE_URL=
# MODELING_AGENT_CARD_BASE_URL=